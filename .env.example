# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Origen permitido para CORS (URL del frontend)
CLIENT_ORIGIN=http://localhost:5173

# Secreto para firmar los JWT de sesión (cambiar en producción)
JWT_SECRET=cambiame-en-produccion

# ─── Base de datos (PostgreSQL) ──────────────────────────────────────────────
DATABASE_URL=postgres://punky:punky_dev@localhost:5432/punky_intranet

# ─── Notificaciones: Email ───────────────────────────────────────────────────
# EMAIL_PROVIDER: console | smtp
EMAIL_PROVIDER=console
EMAIL_FROM="Punky Partners <notificaciones@punkypartners.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ─── Notificaciones: WhatsApp ────────────────────────────────────────────────
# WHATSAPP_PROVIDER: console | twilio | cloudapi
WHATSAPP_PROVIDER=console
# Twilio (proveedor actual)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# WhatsApp Business Cloud API (migración futura, ver docs/notificaciones.md)
WA_CLOUD_PHONE_NUMBER_ID=
WA_CLOUD_ACCESS_TOKEN=

# ─── Integración Profit Plus 2K12 (SQL Server) ───────────────────────────────
# PROFIT_PLUS_MODE: simulado | sqlserver
PROFIT_PLUS_MODE=simulado
PP_DB_HOST=
PP_DB_PORT=1433
PP_DB_NAME=
PP_DB_USER=
PP_DB_PASSWORD=
