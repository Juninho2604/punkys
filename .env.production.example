# ─────────────────────────────────────────────────────────────────────────────
# Variables de PRODUCCIÓN para Docker Compose.
# En el VPS:  cp .env.production.example .env   y rellenar los valores.
# El archivo .env NO se sube a git (está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Obligatorias ─────────────────────────────────────────────────────────────
# Contraseña de PostgreSQL (genera una fuerte, ej: openssl rand -base64 24)
POSTGRES_PASSWORD=

# Secreto para firmar los JWT de sesión (genera uno: openssl rand -base64 48)
JWT_SECRET=

# Clave del Centro de Operaciones (modo TV, solo lectura).
# Genera una: openssl rand -hex 16 · URL del TV: http://TU_IP:8080/tv/<clave>
# Vacía = modo TV deshabilitado.
TV_ACCESS_KEY=

# ── Red / seguridad ──────────────────────────────────────────────────────────
# Puerto del host donde se publica la intranet. Por defecto 8080 (el 80 puede
# estar ocupado por otro servicio del VPS). El sitio queda en http://TU_IP:8080
WEB_PORT=8080

# Mientras se sirva por IP en HTTP: dejar COOKIE_SECURE=false.
# Al activar dominio con HTTPS: CLIENT_ORIGIN=https://tudominio.com y COOKIE_SECURE=true
# Incluí el puerto si no es 80/443: http://TU_IP_PUBLICA:8080
CLIENT_ORIGIN=http://TU_IP_PUBLICA:8080
COOKIE_SECURE=false

# Token del puente de datos (Fase 1): los extractores de la PC del cliente
# suben el inventario real con este token. Genera uno: openssl rand -hex 24
# Vacío = ingesta deshabilitada.
SYNC_TOKEN=

# Réplica directa de Profit (punky-sync por túnel Tailscale, ver
# docs/replica-profit.md). PG_BIND = IP de Tailscale del VPS (100.x.y.z)
# para que el 5432 exista SOLO dentro del túnel. Sin definir = solo localhost.
# ¡NUNCA poner aquí la IP pública ni 0.0.0.0!
PG_BIND=127.0.0.1

# ── Notificaciones: Email ────────────────────────────────────────────────────
# console = imprime en el log · smtp = envío real
EMAIL_PROVIDER=console
EMAIL_FROM=Punky Partners <notificaciones@punkypartners.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ── Notificaciones: WhatsApp ─────────────────────────────────────────────────
# console = imprime en el log · twilio (actual) · cloudapi (futuro)
WHATSAPP_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WA_CLOUD_PHONE_NUMBER_ID=
WA_CLOUD_ACCESS_TOKEN=

# ── Profit Plus 2K12 ─────────────────────────────────────────────────────────
# simulado | pipeline (inventario real vía puente de datos) | sqlserver
PROFIT_PLUS_MODE=simulado
PP_DB_HOST=
PP_DB_PORT=1433
PP_DB_NAME=
PP_DB_USER=
PP_DB_PASSWORD=
